{
  "name": "@madojs/mado",
  "version": "0.12.0",
  "description": "A calm native-first web framework for sites and apps. Web Components, signals, routing, data, forms and browser-rendered static snapshots. Zero runtime dependencies.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "framework",
    "native-first",
    "web-components",
    "declarative-shadow-dom",
    "signals",
    "tagged-templates",
    "router",
    "vite",
    "static-snapshot",
    "spa",
    "minimal"
  ],
  "homepage": "https://github.com/madojs/mado#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/madojs/mado.git"
  },
  "bugs": {
    "url": "https://github.com/madojs/mado/issues"
  },
  "bin": {
    "mado": "./scripts/cli.mjs"
  },
  "main": "./dist/src/index.js",
  "module": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./devtools.js": {
      "types": "./dist/src/devtools.d.ts",
      "import": "./dist/src/devtools.js"
    },
    "./vite": {
      "types": "./dist/src/vite/index.d.ts",
      "import": "./dist/src/vite/index.js"
    }
  },
  "files": [
    "dist/src",
    "scripts",
    "templates",
    "starters",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "AGENTS.md",
    "llms.txt",
    "docs/README.md",
    "docs/en/**/*.md",
    "docs/architecture/**/*.md",
    "docs/recipes/**/*"
  ],
  "scripts": {
    "build": "node scripts/cli.mjs build",
    "watch": "node scripts/cli.mjs watch",
    "dev": "node scripts/cli.mjs dev",
    "static": "node scripts/cli.mjs static",
    "preview": "node scripts/cli.mjs preview",
    "new": "node scripts/cli.mjs new",
    "size": "node scripts/size-budget.mjs",
    "package:smoke": "node scripts/package-smoke.mjs",
    "docs:lint": "node scripts/docs-lint.mjs",
    "api:check": "node scripts/api-check.mjs",
    "benchmark:static": "node scripts/benchmark-static.mjs",
    "test": "node scripts/cli.mjs test",
    "typecheck": "node scripts/cli.mjs typecheck",
    "clean": "rm -rf dist out",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "esbuild": "^0.28.1",
    "linkedom": "^0.18.13",
    "playwright-core": "^1.61.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  },
  "peerDependencies": {
    "playwright-core": "^1.47.0",
    "vite": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "playwright-core": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.12"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
